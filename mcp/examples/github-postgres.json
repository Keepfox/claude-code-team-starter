{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "${GITHUB_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${GITHUB_MCP_TOKEN}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${POSTGRES_CONNECTION_STRING}"
      ],
      "env": {
        "POSTGRES_SSL_MODE": "${POSTGRES_SSL_MODE:-require}"
      }
    }
  }
}
